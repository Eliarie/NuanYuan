/* ── Layout ── */
.teacher-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: transparent;
}

/* ── Header ── */
.top-head {
  padding: 88rpx 32rpx 20rpx;
  padding-top: calc(88rpx + constant(safe-area-inset-top));
  padding-top: calc(88rpx + env(safe-area-inset-top));
  background: linear-gradient(170deg, #f3ecdc 0%, #f8f5ee 72%);
  border-bottom: 1rpx solid #ede8de;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.brand-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.brand-mini { width: 52rpx; height: 52rpx; }
.brand-word { width: 172rpx; height: 40rpx; }

.head-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.meta {
  font-size: 24rpx;
  color: #6f6a61;
  font-weight: 700;
}

.team-dot-wrap {
  display: flex;
  align-items: center;
  gap: 5rpx;
  padding: 8rpx 12rpx;
  background: rgba(207,181,122,.18);
  border-radius: 999rpx;
}

.team-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #cfb57a;
}

/* ── Body ── */
.body-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.pane {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding: 24rpx 24rpx 32rpx;
}

/* ── Chat ── */
.chat-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 16rpx;
}

.day-tip {
  text-align: center;
  font-size: 22rpx;
  color: #b8ae96;
  margin-bottom: 4rpx;
}

.msg {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.msg.right { flex-direction: row-reverse; }

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f9c74f, #ffe066);
  font-size: 28rpx;
  flex-shrink: 0;
}

.avatar.ai {
  background: linear-gradient(135deg, #ffe0cc, #ffd0a0);
}

.bubble {
  max-width: 500rpx;
  border-radius: 24rpx;
  padding: 18rpx 22rpx;
  font-size: 27rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.bubble.teacher {
  background: #e8d49a;
  border-bottom-right-radius: 6rpx;
  color: #3a3020;
}

.bubble.ai {
  background: #fdfcf8;
  border: 1rpx solid #ece5d4;
  border-bottom-left-radius: 6rpx;
  color: #3a3020;
}

.bubble-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: flex-start;
}

.action-chip {
  background: #3a3020;
  color: #f5efe0;
  border-radius: 999rpx;
  padding: 10rpx 26rpx;
  font-size: 25rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
}

/* ── Chat Input ── */
.chat-input-bar {
  border-top: 1rpx solid #ece6d8;
  background: #f5efe3;
  padding: 14rpx 18rpx calc(14rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.voice-bar, .text-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mic-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #efb7d4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
  transition: transform 0.15s;
}

.mic-btn:active { transform: scale(0.93); }
.mic-btn.recording { background: #ff6b6b; }

.voice-preview {
  flex: 1;
  min-height: 44rpx;
  border-radius: 999rpx;
  border: 1rpx solid #ddd1ba;
  background: #fffef9;
  padding: 10rpx 20rpx;
  font-size: 25rpx;
  display: flex;
  align-items: center;
}

.voice-preview.ph { color: #b8ae96; }
.voice-preview.listening { color: #c8960a; }

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 1rpx solid #ddd1ba;
  background: #f8f3e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.chat-input {
  flex: 1;
  border: 1rpx solid #ddd1ba;
  border-radius: 999rpx;
  padding: 12rpx 20rpx;
  background: #fdfcf8;
  font-size: 27rpx;
  color: #3a3020;
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #3a3020;
  color: #f5efe0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

/* ── Child List ── */
.search-bar {
  background: #fdfcf8;
  border-radius: 22rpx;
  padding: 14rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(80,60,0,.06);
}

.search-icon { font-size: 28rpx; color: #b8ae96; }

.search-ipt {
  flex: 1;
  font-size: 27rpx;
  color: #4f4a43;
}

.child-list {
  background: #fdfcf8;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(80,60,0,.07);
  margin-bottom: 20rpx;
}

.child-row {
  border-left: 6rpx solid #e8e0d0;
  transition: background 0.15s;
}

.child-row.amber { border-left-color: #f9c74f; }
.child-row.green { border-left-color: #7ec87e; }
.child-row:not(:last-child) { border-bottom: 1rpx solid #f2edd8; }
.child-row:active { background: #fdf8ec; }

.row-main {
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.child-avatar-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff8e6;
  flex-shrink: 0;
}

.child-avatar-wrap.amber { background: #fff8e0; }
.child-avatar-wrap.green { background: #f0faf0; }

.child-emoji { font-size: 36rpx; }

.row-info { flex: 1; }

.row-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2c2a;
}

.row-status {
  margin-top: 5rpx;
  font-size: 23rpx;
}

.row-status.amber { color: #c49a20; }
.row-status.green { color: #5a9e5a; }

.arrow {
  font-size: 34rpx;
  color: #c8be9e;
}

/* ── Add Child Button ── */
.add-child-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #fdfcf8;
  border: 2rpx dashed #d4c89a;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-top: 4rpx;
  transition: background 0.15s;
}

.add-child-btn:active { background: #fdf8ec; }

.add-icon {
  font-size: 36rpx;
  color: #c8a84a;
  font-weight: 300;
  line-height: 1;
}

.add-label {
  font-size: 28rpx;
  color: #c8a84a;
  font-weight: 600;
}

.empty-tip {
  text-align: center;
  font-size: 25rpx;
  color: #b8ae96;
  padding: 24rpx 0;
}

/* ── Review Tab ── */
.teacher-profile-card {
  background: #f3dfb3;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(90,74,44,.1);
}

.tp-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.tp-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #3b3427;
}

.tp-role, .tp-stats {
  font-size: 22rpx;
  color: #6b5e3e;
  margin-top: 4rpx;
  opacity: 0.9;
}

.kpi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.kpi-card {
  background: #fdfcf8;
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 3rpx 10rpx rgba(80,60,0,.06);
}

.kpi-num {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
}

.kpi-num.gold { color: #c8960a; }
.kpi-num.green { color: #5a9e5a; }
.kpi-num.blue { color: #4a9eff; }

.kpi-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a7a50;
}

.section-card {
  background: #fdfcf8;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 3rpx 10rpx rgba(80,60,0,.06);
}

.section-label {
  font-size: 25rpx;
  font-weight: 700;
  color: #8a7a50;
  margin-bottom: 14rpx;
}

.section-body {
  font-size: 26rpx;
  line-height: 1.8;
  color: #3d2e00;
}

/* Pending approval */
.pending-item {
  border-top: 1rpx solid #f2edd8;
  padding-top: 14rpx;
  margin-top: 14rpx;
}

.pending-from {
  font-size: 22rpx;
  color: #b8ae96;
  margin-bottom: 6rpx;
}

.pending-text {
  font-size: 25rpx;
  color: #3d2e00;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.pending-actions {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
}

.pill-btn {
  border-radius: 999rpx;
  padding: 8rpx 22rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: #f9c74f;
  color: #3d2e00;
}

.pill-btn.ghost {
  background: #f0e8c8;
  color: #8a7a50;
}

/* ── Mine Tab ── */
.mine-profile-card {
  background: #f3dfb3;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 18rpx rgba(90,74,44,.1);
}

.mine-avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.35);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mine-emoji { font-size: 40rpx; }

.mine-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #3b3427;
}

.mine-role {
  font-size: 22rpx;
  color: #6b5e3e;
  margin-top: 4rpx;
}

.stats-row {
  background: #fdfcf8;
  border-radius: 22rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  box-shadow: 0 3rpx 10rpx rgba(80,60,0,.06);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #3b3427;
}

.stat-label {
  font-size: 21rpx;
  color: #8a7a50;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e8e0d0;
}

/* Team members */
.team-member-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f2edd8;
}

.team-member-row:last-child { border-bottom: none; }

.tm-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #fff8e6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.tm-info { flex: 1; }

.tm-name {
  font-size: 27rpx;
  font-weight: 700;
  color: #3b3427;
}

.tm-role {
  font-size: 22rpx;
  color: #8a7a50;
  margin-top: 3rpx;
}

.tm-badge {
  font-size: 21rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #f0e8c8;
  color: #8a7a50;
}

.tm-badge.admin {
  background: #f9c74f;
  color: #3d2e00;
  font-weight: 700;
}

.team-chat-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  background: #f8f3e8;
  border-radius: 16rpx;
  font-size: 27rpx;
  color: #3d2e00;
  font-weight: 600;
}

.tc-arrow { color: #c8be9e; font-size: 32rpx; }

/* Settings */
.settings-card {
  background: #fdfcf8;
  border-radius: 22rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 3rpx 10rpx rgba(80,60,0,.06);
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid #f2edd8;
}

.setting-row:last-child { border-bottom: none; }

.setting-label {
  font-size: 27rpx;
  color: #3d2e00;
}

.setting-value {
  font-size: 25rpx;
  color: #c8960a;
}

.toggle {
  width: 72rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: #e0d8c8;
  position: relative;
  transition: background 0.2s;
}

.toggle::after {
  content: '';
  position: absolute;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #fff;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.2s;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,.15);
}

.toggle.on { background: #f9c74f; }
.toggle.on::after { left: 38rpx; }

.logout-btn {
  border-radius: 999rpx;
  border: 1rpx solid #d9ccb3;
  background: #fdfcf8;
  color: #907c57;
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

/* ── Tab Bar ── */
.tabbar {
  display: flex;
  background: #f8f6f1;
  border-top: 1rpx solid #ece8de;
  padding: 12rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  font-size: 21rpx;
  color: #9c9488;
  transition: color 0.2s;
}

.tab.on {
  color: #c8960a;
  font-weight: 700;
}

.tab-icon {
  font-size: 34rpx;
  line-height: 1;
}

/* ── Modals ── */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(40,30,10,.4);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.sheet {
  width: 100%;
  background: #fffdf5;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
}

.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #ddd5c0;
  margin: 0 auto 20rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2f2c2a;
  margin-bottom: 6rpx;
}

.sheet-sub {
  font-size: 23rpx;
  color: #b8ae96;
  margin-bottom: 20rpx;
}

.ta {
  width: 100%;
  min-height: 200rpx;
  border: 1rpx solid #e8d870;
  border-radius: 18rpx;
  background: #fff;
  padding: 16rpx;
  font-size: 27rpx;
  color: #3d2e00;
  box-sizing: border-box;
  margin-bottom: 18rpx;
}

.sheet-actions {
  display: flex;
  gap: 14rpx;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  background: #f9c74f;
  color: #3d2e00;
  font-size: 28rpx;
  font-weight: 700;
  padding: 0;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
}

.btn.ghost {
  background: #f0e8c8;
  color: #8a7a50;
}

/* ── Add Child Form ── */
.form-row {
  margin-bottom: 18rpx;
}

.form-label {
  font-size: 24rpx;
  color: #8a7a50;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  border: 1rpx solid #e8d870;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  font-size: 27rpx;
  background: #fff;
  box-sizing: border-box;
}

.emoji-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.emoji-opt {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f0e4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.15s;
}

.emoji-opt.selected {
  border-color: #f9c74f;
  background: #fff8e0;
}

.status-picker {
  display: flex;
  gap: 12rpx;
}

.status-opt {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #f5f0e4;
  color: #8a7a50;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.status-opt.sel-amber {
  background: #fff8e0;
  border-color: #f9c74f;
  color: #c8960a;
}

.status-opt.sel-green {
  background: #f0faf0;
  border-color: #7ec87e;
  color: #5a9e5a;
}
