.teacher-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.top-head {
  padding: 84rpx 28rpx 20rpx;
  padding-top: calc(84rpx + constant(safe-area-inset-top));
  padding-top: calc(84rpx + env(safe-area-inset-top));
  background: linear-gradient(170deg, #f2e8d5 0%, #f8f3e7 70%);
  border-bottom: 1px solid #e7decc;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.brand-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.brand-mini {
  width: 56rpx;
  height: 56rpx;
}

.brand-word {
  width: 180rpx;
  height: 42rpx;
}

.meta {
  font-size: 24rpx;
  color: #756f62;
  font-weight: 700;
}

.body-wrap {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.pane {
  height: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.msg {
  display: flex;
}

.msg.right {
  justify-content: flex-end;
}

.bubble {
  max-width: 560rpx;
  border-radius: 22rpx;
  padding: 16rpx 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.bubble.teacher {
  background: #ecd9ae;
}

.bubble.ai {
  background: #fffef9;
  border: 1px solid #e4dbc8;
}

.send-parent {
  margin: 0 20rpx 20rpx;
  background: #1f1f20;
  color: #f7f1e5;
  text-align: center;
  padding: 20rpx;
  border-radius: 999rpx;
}

.search {
  padding: 18rpx;
  margin-bottom: 16rpx;
}

.archive-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.archive-head .search {
  flex: 1;
  margin-bottom: 0;
}

.add-btn {
  flex-shrink: 0;
  padding: 18rpx 20rpx;
  border-radius: 999rpx;
  background: #1f1f20;
  color: #f7f1e5;
  font-size: 24rpx;
  font-weight: 700;
}

.child-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.child {
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.avatar {
  font-size: 42rpx;
}

.c-name {
  font-size: 30rpx;
  font-weight: 700;
}

.c-status {
  margin-top: 4rpx;
  font-size: 22rpx;
}

.c-status.amber {
  color: #d4a017;
}

.arrow {
  color: #b0a060;
  font-size: 34rpx;
}

.detail {
  margin-top: 14rpx;
  padding: 18rpx;
}

.d-title {
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.dim-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.dim-label {
  width: 132rpx;
  font-size: 24rpx;
}

.dim-bar {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  background: #f1ece0;
  overflow: hidden;
}

.dim-fill {
  height: 100%;
  background: linear-gradient(90deg, #efdb8f, #e8c04f);
}

.dim-val {
  width: 48rpx;
  text-align: right;
  font-size: 22rpx;
  color: #7d7363;
}

.summary,
.profile {
  padding: 24rpx;
}

.sum-title,
.p-name {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.sum-text,
.p-meta {
  font-size: 24rpx;
  line-height: 1.7;
  color: #5f574b;
}

.tabbar {
  min-height: 98rpx;
  border-top: 1px solid #ebe7de;
  background: #fcfcfd;
  display: flex;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab {
  flex: 1;
  text-align: center;
  line-height: 98rpx;
  color: #8d8a85;
  font-size: 22rpx;
}

.tab.on {
  color: #e59554;
  font-weight: 700;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(61, 46, 0, 0.35);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: #fffdf5;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
}

.add-sheet {
  max-height: 86vh;
  overflow-y: auto;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.ta {
  width: 100%;
  min-height: 220rpx;
  border: 1px solid #e8d870;
  border-radius: 16rpx;
  background: #fff;
  padding: 12rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.sheet-actions {
  display: flex;
  gap: 12rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.field.full {
  grid-column: 1 / -1;
}

.field-label {
  font-size: 22rpx;
  color: #8a7a50;
  font-weight: 700;
}

.field-input,
.field-picker,
.field-textarea {
  border: 1px solid #e8d870;
  border-radius: 14rpx;
  background: #fff;
  padding: 12rpx 14rpx;
  font-size: 26rpx;
  color: #3d2e00;
}

.field-textarea {
  min-height: 150rpx;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  background: #f9c74f;
  color: #3d2e00;
  font-size: 26rpx;
  font-weight: 700;
}

.btn.ghost {
  background: #f0e8a0;
}
