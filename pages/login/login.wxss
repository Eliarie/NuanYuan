.login-page {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 44rpx;
  background: linear-gradient(160deg, #f4ecd8 0%, #fbf6ea 76%);
}

.center-wrap {
  width: 100%;
  max-width: 680rpx;
}

.logo-card {
  margin: 0 auto;
  width: 430rpx;
  padding: 44rpx 34rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.brand-icon {
  width: 180rpx;
  height: 180rpx;
}

.brand-wordmark {
  width: 280rpx;
  height: 64rpx;
}

.slogan {
  text-align: center;
  margin-top: 20rpx;
  color: #8e8677;
  font-size: 24rpx;
  letter-spacing: 0.6rpx;
}

.role-list {
  margin-top: 42rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.role-item {
  padding: 30rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border: 1px solid #efe6d7;
}

.emoji {
  font-size: 54rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2c2a;
}

.desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8e8677;
}