.detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6f0e4 0%, #f8f4ec 100%);
}

.head {
  background: #f9c74f;
  padding: 84rpx 28rpx 24rpx;
  padding-top: calc(84rpx + constant(safe-area-inset-top));
  padding-top: calc(84rpx + env(safe-area-inset-top));
  color: #3d2e00;
}

.back {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
  font-size: 46rpx;
  margin-bottom: 10rpx;
}

.name {
  font-size: 38rpx;
  font-weight: 800;
}

.meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

.body {
  height: calc(100vh - 300rpx);
  box-sizing: border-box;
  padding: 18rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
}

.section {
  border-radius: 24rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #8a7a50;
  margin-bottom: 12rpx;
}

.dim-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.dim-label {
  width: 132rpx;
  font-size: 24rpx;
  color: #3d2e00;
}

.dim-bar {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #f1ece0;
}

.dim-fill {
  height: 100%;
  background: linear-gradient(90deg, #efdb8f, #e8c04f);
}

.dim-val {
  width: 52rpx;
  text-align: right;
  font-size: 22rpx;
  color: #d4a017;
}

.tl-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.dot-col {
  width: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 8rpx;
}

.line {
  width: 2rpx;
  flex: 1;
  margin-top: 4rpx;
  background: #e8d870;
}

.tl-date {
  font-size: 22rpx;
  color: #b0a060;
}

.tl-text {
  margin-top: 2rpx;
  font-size: 24rpx;
  color: #3d2e00;
  line-height: 1.6;
}

.send-btn {
  margin-top: 8rpx;
  border-radius: 999rpx;
  background: #f9c74f;
  color: #3d2e00;
  font-size: 26rpx;
  font-weight: 700;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(61, 46, 0, 0.35);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: #fffdf5;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 700;
}

.sheet-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #b0a060;
}

.ta {
  margin-top: 14rpx;
  width: 100%;
  min-height: 220rpx;
  border: 1px solid #e8d870;
  border-radius: 16rpx;
  background: #fff;
  padding: 12rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.sheet-actions {
  display: flex;
  gap: 12rpx;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  background: #f9c74f;
  color: #3d2e00;
  font-size: 26rpx;
  font-weight: 700;
}

.btn.ghost {
  background: #f0e8a0;
}