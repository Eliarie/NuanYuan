<view class="container detail-page">
  <view class="head">
    <view class="back" bindtap="goBack">← 返回孩子档案</view>
    <view class="avatar">{{child.avatar}}</view>
    <view class="name">{{child.name}}</view>
    <view class="meta">{{child.status}} · 小二班</view>
  </view>

  <scroll-view scroll-y class="body">
    <view class="card section">
      <view class="section-title">📊 发展维度</view>
      <view wx:for="{{child.dims}}" wx:key="label" class="dim-row">
        <text class="dim-label">{{item.label}}</text>
        <view class="dim-bar">
          <view class="dim-fill" style="width: {{item.val}}%;"></view>
        </view>
        <text class="dim-val">{{item.val}}</text>
      </view>
    </view>

    <view class="card section">
      <view class="section-title">📋 个案时间线</view>
      <view wx:for="{{child.timeline}}" wx:key="date" class="tl-row">
        <view class="dot-col">
          <view class="dot" style="background: {{item.color || '#D4A017'}}"></view>
          <view class="line" wx:if="{{index < child.timeline.length - 1}}"></view>
        </view>
        <view>
          <view class="tl-date">{{item.date}}</view>
          <view class="tl-text">{{item.text}}</view>
        </view>
      </view>
    </view>

    <button class="send-btn" bindtap="openDraft">✉️ 发消息给家长</button>
  </scroll-view>

  <view class="mask" wx:if="{{showModal}}" bindtap="closeDraft">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">发消息给家长</view>
      <view class="sheet-sub">AI 已根据今天的情况起草，你可以直接修改</view>
      <textarea class="ta" value="{{draftText}}" bindinput="onDraftInput" maxlength="500" />
      <view class="sheet-actions">
        <button class="btn ghost" bindtap="closeDraft">取消</button>
        <button class="btn" bindtap="confirmSend">{{sendBtnText}}</button>
      </view>
    </view>
  </view>
</view>