<view class="container teacher-page">

  <!-- ── Header ── -->
  <view class="top-head">
    <view class="brand-stack">
      <view class="brand-line">
        <image class="brand-mini" src="/assets/logo01.png" mode="aspectFit" />
        <image class="brand-word" src="/assets/logo02.png" mode="aspectFit" />
      </view>
      <view class="brand-slogan">Better Connections, real Growth.</view>
    </view>
    <view class="head-right">
      <view class="meta">{{roleMeta}}</view>
      <view class="team-dot-wrap" bindtap="openTeamPanel">
        <view class="team-dot"></view>
        <view class="team-dot"></view>
        <view class="team-dot"></view>
      </view>
    </view>
  </view>

  <!-- ── Body ── -->
  <view class="body-wrap">

    <!-- Tab 0: 树洞 -->
    <block wx:if="{{activeTab === 0}}">
      <scroll-view scroll-y class="pane">
        <view class="chat-list">
          <view class="day-tip">今天 · 14:32</view>

          <view class="msg right">
            <view class="bubble teacher">今天小明又打人了，我真的很崩溃，不知道该怎么办了...</view>
            <view class="avatar">👩‍🏫</view>
          </view>

          <view class="msg left">
            <view class="avatar ai">🌱</view>
            <view class="bubble ai">听起来今天真的很累了，带着这么多孩子还要处理突发情况，你已经很不容易了。\n\n小明上次也有类似的情况，你当时试了冷处理的方法，后来效果怎么样？</view>
          </view>

          <view class="msg right">
            <view class="bubble teacher">冷处理有点用，但不稳定</view>
            <view class="avatar">👩‍🏫</view>
          </view>

          <view class="msg left">
            <view class="avatar ai">🌱</view>
            <view class="bubble-group">
              <view class="bubble ai">这很正常，行为改变需要时间和一致性。可以在情绪平稳时做角色扮演，练习"我想要这个玩具，可以借我吗？"。\n\n需要我帮你起草一条给家长的建议吗？</view>
              <view class="action-chip" bindtap="openDraft">发送给家长 →</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="chat-input-bar">
        <block wx:if="{{inputMode === 'voice'}}">
          <view class="voice-bar">
            <view class="mic-btn {{isRecording ? 'recording' : ''}}" bindtap="toggleRecord">
              <text>{{isRecording ? '⏹️' : '🎙️'}}</text>
            </view>
            <view class="voice-preview {{isRecording ? 'listening' : 'ph'}}">{{voicePreview}}</view>
            <view class="icon-btn" bindtap="toTextMode">⌨️</view>
          </view>
        </block>
        <block wx:else>
          <view class="text-bar">
            <view class="icon-btn" bindtap="toVoiceMode">🎙️</view>
            <input class="chat-input" placeholder="说说今天发生了什么…" value="{{chatDraft}}" bindinput="onChatInput" confirm-type="send" bindconfirm="sendChat" />
            <view class="send-btn" bindtap="sendChat">➤</view>
          </view>
        </block>
      </view>
    </block>

    <!-- Tab 1: 孩子档案 -->
    <block wx:if="{{activeTab === 1}}">
      <scroll-view scroll-y class="pane">
        <view class="search-bar">
          <text class="search-icon">🔍</text>
          <input class="search-ipt" placeholder="搜索孩子姓名…" value="{{keyword}}" bindinput="onKeywordInput" />
        </view>

        <view class="child-list">
          <view wx:for="{{filteredChildren}}" wx:key="name"
            class="child-row {{item.statusClass}}"
            data-name="{{item.name}}"
            bindtap="openChild">
            <view class="row-main">
              <view class="child-avatar-wrap {{item.statusClass}}">
                <text class="child-emoji">{{item.avatar}}</text>
              </view>
              <view class="row-info">
                <view class="row-name">{{item.name}}</view>
                <view class="row-status {{item.statusClass}}">● {{item.status}}</view>
              </view>
              <view class="arrow">›</view>
            </view>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="empty-tip" wx:if="{{filteredChildren.length === 0}}">
          <text>未找到匹配的孩子</text>
        </view>

        <!-- 添加孩子按钮 -->
        <view class="add-child-btn" bindtap="openAddChild">
          <text class="add-icon">＋</text>
          <text class="add-label">添加孩子</text>
        </view>
      </scroll-view>
    </block>

    <!-- Tab 2: 回顾 -->
    <block wx:if="{{activeTab === 2}}">
      <scroll-view scroll-y class="pane">

        <!-- 教师信息卡 -->
        <view class="teacher-profile-card">
          <view class="tp-avatar">👩‍🏫</view>
          <view class="tp-info">
            <view class="tp-name">李老师</view>
            <view class="tp-role">小二班主班 · 入职第3年</view>
            <view class="tp-stats">本月处理个案 6 件 · 发送家长消息 14 条</view>
          </view>
        </view>

        <!-- KPI 网格 -->
        <view class="kpi-grid">
          <view class="kpi-card">
            <view class="kpi-num gold">14</view>
            <view class="kpi-label">家长沟通次数</view>
          </view>
          <view class="kpi-card">
            <view class="kpi-num gold">6</view>
            <view class="kpi-label">处理个案数</view>
          </view>
          <view class="kpi-card">
            <view class="kpi-num green">4</view>
            <view class="kpi-label">策略有效案例</view>
          </view>
          <view class="kpi-card">
            <view class="kpi-num blue">21</view>
            <view class="kpi-label">树洞对话次数</view>
          </view>
        </view>

        <!-- AI 月度总结 -->
        <view class="section-card">
          <view class="section-label">🤖 AI 月度总结</view>
          <view class="section-body">本月你处理了 6 个个案，其中情绪管理类 4 件、社交发展类 2 件。有效策略为"冷处理 + 事后复盘"，角色扮演练习帮助孩子建立了语言替代行为。建议持续关注小丽的分离焦虑，并与家长约定固定入园仪式。</view>
        </view>

        <!-- 待审批消息 -->
        <view class="section-card" wx:if="{{isAdmin}}">
          <view class="section-label">📬 待审批发送</view>
          <view wx:for="{{pendingMessages}}" wx:key="id" class="pending-item">
            <view class="pending-from">{{item.from}} 起草</view>
            <view class="pending-text">{{item.text}}</view>
            <view class="pending-actions">
              <view class="pill-btn ghost" data-id="{{item.id}}" bindtap="rejectMsg">拒绝</view>
              <view class="pill-btn" data-id="{{item.id}}" bindtap="approveMsg">批准发送</view>
            </view>
          </view>
          <view class="empty-tip" wx:if="{{pendingMessages.length === 0}}">暂无待审批消息</view>
        </view>

      </scroll-view>
    </block>

    <!-- Tab 3: 我的 -->
    <block wx:if="{{activeTab === 3}}">
      <scroll-view scroll-y class="pane">

        <!-- 个人信息卡 -->
        <view class="mine-profile-card">
          <view class="mine-avatar-wrap">
            <text class="mine-emoji">👩‍🏫</text>
          </view>
          <view class="mine-info">
            <view class="mine-name">李老师</view>
            <view class="mine-role">小二班主班教师 · 入职第3年</view>
          </view>
        </view>

        <!-- 班级数据 -->
        <view class="stats-row">
          <view class="stat-item">
            <view class="stat-num">20</view>
            <view class="stat-label">班级人数</view>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <view class="stat-num">2</view>
            <view class="stat-label">需关注孩子</view>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <view class="stat-num">3年</view>
            <view class="stat-label">教龄</view>
          </view>
        </view>

        <!-- 班级团队 -->
        <view class="section-card">
          <view class="section-label">👥 班级团队</view>
          <view wx:for="{{teamMembers}}" wx:key="name" class="team-member-row">
            <view class="tm-avatar">{{item.emoji}}</view>
            <view class="tm-info">
              <view class="tm-name">{{item.name}}</view>
              <view class="tm-role">{{item.role}}</view>
            </view>
            <view class="tm-badge {{item.isAdmin ? 'admin' : ''}}">{{item.isAdmin ? '管理员' : '成员'}}</view>
          </view>
        </view>

        <!-- 设置项 -->
        <view class="settings-card">
          <view class="setting-row" bindtap="noop">
            <text class="setting-label">班级邀请码</text>
            <text class="setting-value">生成 / 管理 ›</text>
          </view>
          <view class="setting-row" bindtap="noop">
            <text class="setting-label">消息通知</text>
            <view class="toggle on"></view>
          </view>
        </view>

        <button class="logout-btn" bindtap="logout">退出登录</button>
      </scroll-view>
    </block>

  </view>

  <!-- ── Tab Bar ── -->
  <view class="tabbar" wx:if="{{!showModal && !showAddChild && !showTeamPanel}}">
    <view class="tab {{activeTab===0 ? 'on' : ''}}" data-idx="0" bindtap="switchTab">
      <view class="tab-icon icon-chat"></view>
      <text>树洞</text>
    </view>
    <view class="tab {{activeTab===1 ? 'on' : ''}}" data-idx="1" bindtap="switchTab">
      <view class="tab-icon icon-child"></view>
      <text>孩子档案</text>
    </view>
    <view class="tab {{activeTab===2 ? 'on' : ''}}" data-idx="2" bindtap="switchTab">
      <view class="tab-icon icon-stats"></view>
      <text>回顾</text>
    </view>
    <view class="tab {{activeTab===3 ? 'on' : ''}}" data-idx="3" bindtap="switchTab">
      <view class="tab-icon icon-me"></view>
      <text>我的</text>
    </view>
  </view>

  <!-- ── 发消息给家长 Modal ── -->
  <view class="mask" wx:if="{{showModal}}" bindtap="closeDraft">
    <view class="sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-title">发消息给家长</view>
      <view class="sheet-sub">AI 已根据今天的情况起草，你可以直接修改后提交审批</view>
      <textarea class="ta" value="{{draftText}}" bindinput="onDraftInput" maxlength="500" auto-height />
      <view class="sheet-actions">
        <button class="btn ghost" bindtap="closeDraft">取消</button>
        <button class="btn" bindtap="confirmSend">{{sendBtnText}}</button>
      </view>
    </view>
  </view>

  <!-- ── 添加孩子 Modal ── -->
  <view class="mask" wx:if="{{showAddChild}}" bindtap="closeAddChild">
    <view class="sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-title">添加孩子</view>
      <view class="sheet-sub">填写基本信息，档案将共享给班级所有老师</view>
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="孩子姓名" value="{{newChild.name}}" bindinput="onNewChildName" />
      </view>
      <view class="form-row">
        <text class="form-label">头像</text>
        <view class="emoji-picker">
          <view wx:for="{{emojiOptions}}" wx:key="*this"
            class="emoji-opt {{newChild.avatar === item ? 'selected' : ''}}"
            data-emoji="{{item}}" bindtap="pickEmoji">{{item}}</view>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">状态</text>
        <view class="status-picker">
          <view class="status-opt {{newChild.statusClass === 'amber' ? 'sel-amber' : ''}}"
            data-status="amber" data-label="需关注" bindtap="pickStatus">需关注</view>
          <view class="status-opt {{newChild.statusClass === 'green' ? 'sel-green' : ''}}"
            data-status="green" data-label="良好" bindtap="pickStatus">良好</view>
        </view>
      </view>
      <view class="sheet-actions">
        <button class="btn ghost" bindtap="closeAddChild">取消</button>
        <button class="btn" bindtap="submitAddChild">添加</button>
      </view>
    </view>
  </view>

  <!-- ── 班级团队面板 ── -->
  <view class="mask" wx:if="{{showTeamPanel}}" bindtap="closeTeamPanel">
    <view class="sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-title">班级团队</view>
      <view class="sheet-sub">小二班 · 共 {{teamMembers.length}} 位老师</view>
      <view wx:for="{{teamMembers}}" wx:key="name" class="team-member-row">
        <view class="tm-avatar">{{item.emoji}}</view>
        <view class="tm-info">
          <view class="tm-name">{{item.name}}</view>
          <view class="tm-role">{{item.role}}</view>
        </view>
        <view class="tm-badge {{item.isAdmin ? 'admin' : ''}}">{{item.isAdmin ? '管理员' : '成员'}}</view>
      </view>
      <view class="team-chat-entry" bindtap="openTeamChat">
        <text>💬 打开班级讨论群</text>
        <text class="tc-arrow">›</text>
      </view>
      <button class="btn" style="margin-top:16rpx" bindtap="closeTeamPanel">关闭</button>
    </view>
  </view>

</view>
