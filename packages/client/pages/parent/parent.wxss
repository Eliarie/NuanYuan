/* ── Layout ── */
.parent-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── Header ── */
.top-head {
  padding: 84rpx 28rpx 18rpx;
  padding-top: calc(84rpx + constant(safe-area-inset-top));
  padding-top: calc(84rpx + env(safe-area-inset-top));
  background: linear-gradient(170deg, #f2e8d5 0%, #f8f3e7 70%);
  border-bottom: 1rpx solid #ede8de;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-shrink: 0;
}

.brand-stack {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
  flex: 1;
}

.brand-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.brand-mini { width: 46rpx; height: 46rpx; }
.brand-word { width: 156rpx; height: 36rpx; }

.brand-slogan {
  font-size: 20rpx;
  color: #706c66;
  letter-spacing: 0.2rpx;
  line-height: 1.2;
}

.meta {
  font-size: 22rpx;
  color: #756f62;
  font-weight: 700;
  line-height: 1.2;
  text-align: right;
  padding-top: 2rpx;
}

/* ── Body ── */
.body-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.pane {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding: 20rpx 20rpx 28rpx;
}

/* ── Child Head ── */
.child-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.child-avatar {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f9c74f, #ffe066);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.child-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #2f2c2a;
}

.child-desc {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #b8ae96;
}

/* ── Notice Card ── */
.notice-card {
  background: #fdfcf8;
  border-radius: 22rpx;
  border-left: 6rpx solid #f9c74f;
  padding: 16rpx 18rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 3rpx 12rpx rgba(80,60,0,.06);
}

.notice-tag {
  font-size: 21rpx;
  color: #c8960a;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.notice-text {
  font-size: 23rpx;
  line-height: 1.8;
  color: #3d2e00;
  white-space: pre-wrap;
}

.notice-time {
  margin-top: 10rpx;
  font-size: 19rpx;
  color: #b8ae96;
}

/* ── Section Title ── */
.sec-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #3d2e00;
  margin-bottom: 12rpx;
}

/* ── Activity List ── */
.act-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.act-card {
  background: #fdfcf8;
  border-radius: 18rpx;
  padding: 14rpx 16rpx;
  display: flex;
  gap: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(80,60,0,.05);
}

.act-date {
  font-size: 20rpx;
  color: #b8ae96;
  white-space: nowrap;
  padding-top: 2rpx;
  flex-shrink: 0;
}

.act-text {
  font-size: 23rpx;
  line-height: 1.6;
  color: #3d2e00;
}

/* ── Chat ── */
.chat-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.chat-pane {
  flex: 1;
  height: 0;
  padding: 20rpx;
}

.msg {
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.msg.user { justify-content: flex-end; }

.ai-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffe0cc, #ffd0a0);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.bubble {
  max-width: 520rpx;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  font-size: 23rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.bubble.user {
  background: #efb7d4;
  color: #3a2030;
  border-bottom-right-radius: 6rpx;
}

.bubble.ai {
  background: #fdfcf8;
  border: 1rpx solid #ece5d4;
  color: #3a3020;
  border-bottom-left-radius: 6rpx;
}

/* ── Input Row ── */
.input-row {
  border-top: 1rpx solid #ece6d8;
  background: #f5efe3;
  padding: 12rpx 16rpx calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.ipt {
  flex: 1;
  border: 1rpx solid #ddd1ba;
  border-radius: 999rpx;
  background: #fdfcf8;
  padding: 11rpx 18rpx;
  font-size: 23rpx;
  color: #3a3020;
}

.send-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #3a3020;
  color: #f5efe0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

/* ── Tell Teacher ── */
.ta {
  width: 100%;
  min-height: 200rpx;
  border: 1rpx solid #e8d870;
  border-radius: 18rpx;
  background: #fff;
  padding: 14rpx;
  font-size: 23rpx;
  color: #3d2e00;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  display: block;
}

.submit-btn {
  border-radius: 999rpx;
  background: #f9c74f;
  color: #3d2e00;
  font-size: 24rpx;
  font-weight: 700;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
}

/* ── Review Tab ── */
.review-hero {
  background: #f3dfb3;
  border-radius: 24rpx;
  padding: 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(90,74,44,.1);
}

.rh-avatar {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.rh-name {
  font-size: 29rpx;
  font-weight: 800;
  color: #3b3427;
}

.rh-desc {
  font-size: 20rpx;
  color: #6b5e3e;
  margin-top: 4rpx;
}

.review-section-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #8a7a50;
  margin-bottom: 12rpx;
  margin-top: 4rpx;
}

.review-card {
  background: #fdfcf8;
  border-radius: 18rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(80,60,0,.05);
  border-left: 5rpx solid #f9c74f;
}

.rv-title {
  font-size: 23rpx;
  font-weight: 700;
  color: #3d2e00;
  margin-bottom: 6rpx;
}

.rv-content {
  font-size: 22rpx;
  line-height: 1.7;
  color: #5a4e30;
}

.dim-overview {
  background: #fdfcf8;
  border-radius: 18rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 8rpx rgba(80,60,0,.05);
}

.dim-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.dim-row:last-child { margin-bottom: 0; }

.dim-label {
  width: 130rpx;
  font-size: 22rpx;
  color: #3d2e00;
  flex-shrink: 0;
}

.dim-bar {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  background: #f1ece0;
  overflow: hidden;
}

.dim-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #efdb8f, #e8c04f);
}

.dim-val {
  width: 52rpx;
  text-align: right;
  font-size: 20rpx;
  color: #c8960a;
  font-weight: 600;
}

.tip-card {
  background: #fff8e6;
  border-radius: 18rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #f0e0a0;
  margin-bottom: 18rpx;
}

.tip-text {
  font-size: 23rpx;
  line-height: 1.8;
  color: #5a4e30;
}

/* ── Tab Bar ── */
.tabbar {
  display: flex;
  background: #f8f6f1;
  border-top: 1rpx solid #ece8de;
  padding: 10rpx 0 calc(14rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
  box-shadow: 0 -4rpx 14rpx rgba(0, 0, 0, 0.04);
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: #8d8a85;
  transition: color 0.2s;
}

.tab.on {
  color: #e59554;
  font-weight: 700;
}

.tab-icon {
  font-size: 30rpx;
  line-height: 1;
}

