:root {
  --bg-cream: #f2e9d6;
  --panel: #f8f3e7;
  --text: #2f2c2a;
  --muted: #8e8677;
  --gold-1: #cfb57a;
  --gold-2: #a8884f;
}

page {
  height: 100%;
  background: radial-gradient(circle at 8% 10%, #f8f1d5 0%, transparent 34%), radial-gradient(circle at 84% 82%, #f3ddd7 0%, transparent 30%), var(--bg-cream);
  color: var(--text);
  font-family: "PingFang SC", "Hiragino Sans GB", sans-serif;
}

.container {
  min-height: 100vh;
}

.card {
  background: #fffef9;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 22rpx rgba(77, 58, 29, 0.1);
}